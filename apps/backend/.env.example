# Backend environment variables
# Copy this file to `apps/backend/.env` and replace every placeholder value.

# Application runtime
ENVIRONMENT=development
DEBUG=true

# Authentication and security
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Database connection
# Use `localhost` when the backend runs directly on your machine.
# Use `db` when the backend runs inside Docker Compose.
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=api_monitoring
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://postgres:change-me@db:5432/api_monitoring

# Redis connection
# Use `localhost` when the backend runs directly on your machine.
# Use `redis` when the backend runs inside Docker Compose.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email delivery
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=change-me
EMAIL_PASSWORD=change-me
EMAIL_FROM=no-reply@example.com
EMAIL_USE_TLS=true
