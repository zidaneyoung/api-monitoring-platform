# Frontend environment variables
# Copy this file to `apps/web/.env.local` and replace every placeholder value.
# Only variables with the `NEXT_PUBLIC_` prefix are exposed to the browser.

NEXT_PUBLIC_APP_NAME=API Monitoring Platform
NEXT_PUBLIC_APP_ENV=development
# Use localhost when Next.js runs directly on the host. Compose overrides this
# with the backend service hostname for the frontend container.
INTERNAL_API_BASE_URL=http://localhost:8000
SESSION_COOKIE_NAME=amp_session
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
